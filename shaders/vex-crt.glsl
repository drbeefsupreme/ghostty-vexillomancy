// Fetch one texel from the packed SDF array
float sdfFetch(int x, int y) {
    int idx = y * SDF_SIZE + x;
    int packed_idx = idx / 4;
    int byte_idx = 3 - (idx & 3);
    uint packed = sigil_packed[packed_idx];
    return float((packed >> uint(byte_idx * 8)) & 0xFFu) / 255.0;
}

// Bilinear sample the SDF at UV in [0,1]
float sdfSample(vec2 uv) {
    vec2 coord = uv * float(SDF_SIZE) - 0.5;
    vec2 f = fract(coord);
    ivec2 i = ivec2(floor(coord));
    int x0 = clamp(i.x, 0, SDF_SIZE - 1);
    int y0 = clamp(i.y, 0, SDF_SIZE - 1);
    int x1 = clamp(i.x + 1, 0, SDF_SIZE - 1);
    int y1 = clamp(i.y + 1, 0, SDF_SIZE - 1);
    float a = sdfFetch(x0, y0);
    float b = sdfFetch(x1, y0);
    float c = sdfFetch(x0, y1);
    float d = sdfFetch(x1, y1);
    return mix(mix(a, b, f.x), mix(c, d, f.x), f.y);
}



float gold_v2_noise(in vec2 xy, in float seed)
{
    return fract(sin(distance(xy*PHI, xy)*seed)*xy.x*xy.y);
}


void mainImage(out vec4 fragColor, in vec2 fragCoord) {
    vec2 uv = fragCoord.xy / iResolution.xy;

#ifdef CURVE
    // Base CRT screen curvature
    uv = (uv - 0.5) * 2.0;
    uv.xy *= 1.0 + pow((abs(vec2(uv.y, uv.x)) / vec2(CURVE)), vec2(2.0));
    uv = (uv / 2.0) + 0.5;
#endif

    // Scale squeeze down for larger windows — keeps the effect subtle at full screen.
    // 800px is the reference "normal" size; above that it tapers off.
    float squeezeFactor = clamp(800.0 / max(iResolution.x, iResolution.y), 0.2, 1.0);
    float adaptiveSqueeze = EDGE_SQUEEZE * squeezeFactor;

    // Top/bottom edge mask: strongest at top and bottom, fades toward center
    float edgeMaskY = 1.0 - smoothstep(0.0, EDGE_DISTORT_ZONE, min(uv.y, 1.0 - uv.y));

    // Left/right edge mask: strongest at left and right, fades toward center
    float edgeMaskX = 1.0 - smoothstep(0.0, EDGE_DISTORT_ZONE, min(uv.x, 1.0 - uv.x));

    // Horizontal squeeze near top/bottom edges
    float squeezeX = 1.0 + edgeMaskY * adaptiveSqueeze;
    uv.x = clamp((uv.x - 0.5) * squeezeX + 0.5, 0.0, 1.0);

    // Vertical squeeze near left/right edges
    float squeezeY = 1.0 + edgeMaskX * adaptiveSqueeze;
    uv.y = clamp((uv.y - 0.5) * squeezeY + 0.5, 0.0, 1.0);


    // Color fringing
    fragColor.r = texture(iChannel0, vec2(uv.x + 0.0003 * COLOR_FRINGING_SPREAD, uv.y + 0.0003 * COLOR_FRINGING_SPREAD)).x;
    fragColor.g = texture(iChannel0, vec2(uv.x + 0.0000 * COLOR_FRINGING_SPREAD, uv.y - 0.0006 * COLOR_FRINGING_SPREAD)).y;
    fragColor.b = texture(iChannel0, vec2(uv.x - 0.0006 * COLOR_FRINGING_SPREAD, uv.y + 0.0000 * COLOR_FRINGING_SPREAD)).z;
    fragColor.a = texture(iChannel0, uv).a;

    // Ghosting
    fragColor.r += 0.04 * GHOSTING_STRENGTH * texture(iChannel0, GHOSTING_SPREAD * vec2(+0.025, -0.027) + uv.xy).x;
    fragColor.g += 0.02 * GHOSTING_STRENGTH * texture(iChannel0, GHOSTING_SPREAD * vec2(-0.022, -0.020) + uv.xy).y;
    fragColor.b += 0.04 * GHOSTING_STRENGTH * texture(iChannel0, GHOSTING_SPREAD * vec2(-0.020, -0.018) + uv.xy).z;

    // Darken
    fragColor.rgb = mix(fragColor.rgb, fragColor.rgb*fragColor.rgb, DARKEN_MIX);

    // Vignette
    fragColor.rgb *= VIGNETTE_BRIGHTNESS * pow(clamp(uv.x * uv.y * (1.0-uv.x) * (1.0-uv.y), 0.0, 1.0), VIGNETTE_SPREAD);

    // Extra edge fade: darken where squeeze is strongest (all four edges)
    float edgeMask = max(edgeMaskY, edgeMaskX);
    fragColor.rgb *= 1.0 - edgeMask * 0.5;

    // Tint
    fragColor.rgb *= vec3(TINT);

    // Scan lines
    fragColor.rgb *= mix(
        1.0,
        SCAN_LINES_VARIANCE/2.0*(1.0 + sin(2.0*PI * uv.y * iResolution.y/SCAN_LINES_PERIOD)),
        SCAN_LINES_STRENGTH
    );

    // Aperture grille
    int apertureGrilleStep = int(8 * mod(fragCoord.x, APERTURE_GRILLE_PERIOD) / APERTURE_GRILLE_PERIOD);
    float apertureGrilleMask;
    if (apertureGrilleStep < 3)
        apertureGrilleMask = 0.0;
    else if (apertureGrilleStep < 4)
        apertureGrilleMask = mod(8*fragCoord.x, APERTURE_GRILLE_PERIOD) / APERTURE_GRILLE_PERIOD;
    else if (apertureGrilleStep < 7)
        apertureGrilleMask = 1.0;
    else if (apertureGrilleStep < 8)
        apertureGrilleMask = mod(-8*fragCoord.x, APERTURE_GRILLE_PERIOD) / APERTURE_GRILLE_PERIOD;

    fragColor.rgb *= 1.0 - APERTURE_GRILLE_STRENGTH*apertureGrilleMask;

    // Flicker (rgb only — preserves alpha for sigil compositing)
    fragColor.rgb *= 1.0 - FLICKER_STRENGTH/2.0*(1.0 + sin(2.0*PI*FLICKER_FREQUENCY*iTime));

    // Noise
    float noise = smoothstep(0.4, 0.6, gold_v2_noise(fragCoord.xy, fract(iTime*0.001)));
    fragColor.rgb *= clamp(noise + 1.0 - NOISE_CONTENT_STRENGTH, 0.0, 1.0);
    fragColor.rgb = clamp(fragColor.rgb + noise * NOISE_UNIFORM_STRENGTH / 100.0, 0.0, 1.0);

#ifdef BLOOM_SPREAD
    // Bloom
    vec2 step = BLOOM_SPREAD * vec2(1.414) / iResolution.xy;
    for (int i = 0; i < 24; i++) {
        vec3 bloomSample = bloomSamples[i];
        vec4 neighbor = texture(iChannel0, uv + bloomSample.xy * step);
        float luminance = 0.299 * neighbor.r + 0.587 * neighbor.g + 0.114 * neighbor.b;
        fragColor.rgb += luminance * bloomSample.z * neighbor.rgb * BLOOM_STRENGTH;
    }
    fragColor.rgb = clamp(fragColor.rgb, 0.0, 1.0);
#endif

    // Rotating sigil watermark (SDF texture)
    vec2 sigUV = fragCoord.xy / iResolution.xy - 0.5;
    sigUV.x *= iResolution.x / iResolution.y;
    sigUV = sigil_rot(iTime * SIGIL_SPEED) * sigUV;
    sigUV = sigUV / SIGIL_SCALE + 0.5;
    float sigSDF = sdfSample(sigUV);
    // SDF: 0.5 = boundary, < 0.5 = inside shape
    float sigMask = 1.0 - smoothstep(0.47, 0.53, sigSDF);
    // Zero out if outside [0,1] UV bounds
    float inBounds = float(sigUV.x >= 0.0) * float(sigUV.x <= 1.0) * float(sigUV.y >= 0.0) * float(sigUV.y <= 1.0);
    sigMask *= inBounds;
    vec3 sigBg = SIGIL_COLOR * sigMask;

    // Composite sigil behind terminal text, then apply window opacity
    fragColor = vec4(
        fragColor.rgb + sigBg,
        BACKGROUND_OPACITY
    );
}
