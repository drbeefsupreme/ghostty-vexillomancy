# Config syntax crash course
# ==========================
# # The config file consists of simple key-value pairs,
# # separated by equals signs.
# font-family = Iosevka
# window-padding-x = 2
#
# # Spacing around the equals sign does not matter.
# # All of these are identical:
# key=value
# key= value
# key =value
# key = value
#
# # Any line beginning with a # is a comment. It's not possible to put
# # a comment after a config option, since it would be interpreted as a
# # part of the value. For example, this will have a value of "#123abc":
# background = #123abc
#
# # Empty values are used to reset config keys to default.
# key =
#
# # Some config options have unique syntaxes for their value,
# # which is explained in the docs for that config option.
# # Just for example:
# resize-overlay-duration = 4s 200ms

# Vexillomancy Color Scheme
# Inspired by: deep black + yellow text, burnt orange/amber,
# and high-contrast FLAG yellow on black
background = #090907
foreground = #e8d800

# ANSI Colors (0-7)
palette = 0=#0d0c08
palette = 1=#c04010
palette = 2=#7a7020
palette = 3=#d4a800
palette = 4=#2a4a5a
palette = 5=#904010
palette = 6=#806020
palette = 7=#c8b870

# Bright ANSI Colors (8-15)
palette = 8=#282618
palette = 9=#e06020
palette = 10=#b8a030
palette = 11=#f5c800
palette = 12=#507080
palette = 13=#d07030
palette = 14=#c8a050
palette = 15=#f0e8c0

# CRT Shader for that retro terminal look
custom-shader = ghostty-shaders/supreme-crt.glsl
keybind = ctrl+r=reload_config
